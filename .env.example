# === Core API / project ===
# Google AI Studio -> https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyCgWU--LiLT7zdgfL6QwqgmU9QKHuKiNaI

# Base URL that Twilio can reach (for example, your HTTPS tunnel or hosting URL)
PUBLIC_HTTP_BASE_URL=https://conceded-properly-refill.ngrok-free.dev

# Toggle audio logging in console output (recommended true for client systems)
SUPPRESS_AUDIO_LOGS=true

# === Config ===
# Path to the YAML settings file inside the container; usually leave as-is.
ALMA_CONFIG_FILE=config/settings.yaml

# === Voice / Realtime ===
# These tune behaviour of the FastAPI realtime service.
PORT=3001
VOICE=Kore
ASR_MODEL=gemini-2.0-flash-live-001
TEMPERATURE=0.7
LOG_LEVEL=INFO
REALTIME_CONNECT_ATTEMPTS=3
REALTIME_CONNECT_BACKOFF=0.5
REALTIME_CONNECT_BACKOFF_MAX=5.0

# === Observability / Telemetry ===
# Set ENABLE_OTEL=true only if you have an OpenTelemetry collector endpoint.
ENABLE_OTEL=false
OTEL_SERVICE_NAME=s2s-poc
OTEL_ENVIRONMENT=local
# OTEL collector endpoint (for example, http://otel-collector:4317)
OTEL_EXPORTER_OTLP_ENDPOINT=
# Optional OTEL headers (key1=value1,key2=value2)
OTEL_EXPORTER_OTLP_HEADERS=

# === Pilot monitoring ===
PILOT_MONITORING_ENABLED=true
CALL_LEDGER_SQLITE_PATH=./data/monitoring/call_ledger.sqlite3
TRANSCRIPT_HISTORY_ENABLED=true
TRANSCRIPT_HISTORY_DIR=./data/monitoring/transcripts

# === ElevenLabs Text-to-Speech (optional) ===
# ElevenLabs -> https://elevenlabs.io/app/subscription
USE_ELEVENLABS_TTS=false
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
ELEVENLABS_VOICE_ID=YOUR_ELEVENLABS_VOICE_ID
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_OPTIMIZE_LATENCY=0
ELEVENLABS_STABILITY=0.25
ELEVENLABS_SIMILARITY=0.75

# === Reservation guardrails ===
RESERVATION_RATE_LIMIT=5
RESERVATION_RATE_WINDOW=60
RESERVATION_DUPLICATE_WINDOW=86400
RESERVATION_MIN_PHONE_DIGITS=6
RESERVATION_MAX_PHONE_DIGITS=15
RESERVATION_MAX_NOTES_LENGTH=500

# === Project info guardrails ===
PROJECT_INFO_MIN_LENGTH=5
PROJECT_INFO_MAX_QUERY_LENGTH=256
PROJECT_INFO_RATE_LIMIT=30
PROJECT_INFO_RATE_WINDOW=60
PROJECT_INFO_DUPLICATE_WINDOW=30
PROJECT_INFO_BLOCKLIST=

# === Retrieval (LanceDB + embeddings) ===
LANCEDB_PATH=./data/lancedb
DOC_CSV_PATH=./data/docs
DOC_TXT_PATH=./data/docs
DOC_PDF_PATH=./data/docs/source.pdf
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_DEVICE=auto   # auto|cpu|cuda|mps
EMBED_WARMUP=1      # warm model on startup

# === Chunking ===
CHUNK_CHARS=800
CHUNK_OVERLAP=120

# === Search / ranking ===
TOP_K=4
INIT_K=16
EF_SEARCH=32
USE_MMR=true
MMR_LAMBDA=0.6
USE_LEXICAL_BOOST=false
LEXICAL_WEIGHT=0.25
CSV_BIAS=0.12
PDF_BIAS=0.0

# === Twilio (calls + media streams) ===
# Twilio console -> https://console.twilio.com/
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN

# === WhatsApp Business Calling API (SIP) ===
# Apply for access: https://developers.facebook.com/documentation/business-messaging/whatsapp/calling
#
# How to get SIP credentials:
#   GET https://graph.facebook.com/v20.0/{phone-number-id}?fields=sip_trunk_configuration&include_sip_credentials=true
#
# Your server needs a public IP/domain. Meta requires TLS on port 5061.
# Use nginx/haproxy to terminate TLS → forward plain SIP to META_SIP_LISTEN_PORT.
#
# META_SIP_USERNAME  = your WhatsApp phone_number_id (from Meta Business Manager)
# META_SIP_PASSWORD  = the SIP password from the API response above
# META_SIP_MY_IP     = your server's public IP (so SIP responses route correctly)
# META_SIP_LISTEN_PORT = internal port pyVoIP listens on (default 5060, behind nginx TLS)
META_SIP_USERNAME=YOUR_PHONE_NUMBER_ID
META_SIP_PASSWORD=YOUR_META_SIP_PASSWORD
META_SIP_MY_IP=YOUR_PUBLIC_IP
META_SIP_LISTEN_PORT=5060

# === Gemini Live tuning ===
REALTIME_TEMPERATURE=0.7
REALTIME_VOICE=Kore
